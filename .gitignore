# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
ecommerce.sqlite3
media/
staticfiles/
assets/

# If using Django collectstatic
static/

# Python virtual environments
venv/
ENV/
env/
.venv/
.python-version

# Distribution / packaging
.Python
build/
dist/
downloads/
.eggs/
.eggs-info/
.installed.cfg
*.egg-info/
*.egg
*.whl

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django local files
*.sqlite3
*.sqlite3-journal

# Jupyter Notebook
.ipynb_checkpoints

# PyCharm
.idea/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db

# dotenv
.env
.env.*

# mypy
.mypy_cache/
.dmypy.json
.dmypy.json

# Pyre
.pyre/

# Sphinx documentation
docs/_build/

# Coverage and testing reports
coverage/

# JetBrains IDEs
*.iml

# Temporary files
*.bak
*.tmp
*~

# Ignore Python bytecode directories
__pycache__/

# Ignore migrations if you want to keep only source scaffold, uncomment
# core/**/migrations/*.py
# !core/**/migrations/__init__.py
