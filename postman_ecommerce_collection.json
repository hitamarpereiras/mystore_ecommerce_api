    {
      "name": "Auth",
      "item": [
        {
          "name": "Obter Token JWT",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seu-email@example.com\",\n  \"password\": \"sua-senha\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/authentication/token/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "authentication",
                "token",
                ""
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/authentication/token/refresh/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "authentication",
                "token",
                "refresh",
                ""
              ]
            }
          }
        }
      ]
